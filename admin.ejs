<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Trendfit'er Admin Panel</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #121212;
            color: #ffffff;
            margin: 0;
            padding: 40px;
        }
        .container {
            max-width: 900px;
            margin: 0 auto;
        }
        h1, h2 {
            color: #00ff87;
        }
        form {
            background: #1e1e1e;
            padding: 20px;
            border-radius: 8px;
            margin-bottom: 30px;
        }
        input, textarea {
            width: 100%;
            padding: 10px;
            margin: 8px 0;
            box-sizing: border-box;
            background-color: #2a2a2a;
            border: 1px solid #444;
            color: #fff;
        }
        button {
            background: #00ff87;
            color: #000;
            padding: 10px 15px;
            border: none;
            cursor: pointer;
            font-weight: bold;
            border-radius: 4px;
        }
        .product-list {
            display: grid;
            gap: 20px;
        }
        .product-item {
            background: #1e1e1e;
            padding: 15px;
            border-radius: 8px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .item-details {
            display: flex;
            align-items: center;
            gap: 15px;
        }
        .item-img {
            width: 60px;
            height: 60px;
            object-fit: cover;
            border-radius: 4px;
        }
        .drops-grid {
            display: grid;
            gap: 20px;
            margin-bottom: 40px;
        }
        .drop-card {
            background: #1e1e1e;
            border: 1px solid #333;
            border-radius: 12px;
            padding: 20px;
        }
        .drop-card h3 {
            margin-bottom: 14px;
            color: #fff;
        }
        .drop-fields {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 14px;
        }
        .drop-footer {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            align-items: center;
            margin-top: 16px;
        }
    </style>
</head>
<body>

<div class="container">
    <h1>Trendfit'er Admin Panel</h1>
    
    <h2>Add New Item</h2>
    <form action="/admin/add-product" method="POST" enctype="multipart/form-data">
    <div class="form-group">
        <label for="name">Product Name</label>
        <input type="text" id="name" name="name" required>
    </div>

    <div class="form-group">
        <label for="description">Description</label>
        <textarea id="description" name="description" required></textarea>
    </div>

    <div class="form-group">
        <label for="price">Price (PKR)</label>
        <input type="number" id="price" name="price" required>
    </div>

    <div class="form-group">
        <label for="stock">Stock Quantity</label>
        <input type="number" id="stock" name="stock" required>
    </div>

    <div class="form-group">
    <label>Product Images</label>
    <div id="image-inputs-container" style="display: flex; flex-direction: column; gap: 10px;">
        <div class="image-input-wrapper" style="display: flex; gap: 10px; align-items: center;">
            <input type="file" name="images" accept="image/*" required style="flex-grow: 1;">
        </div>
    </div>
    <button type="button" onclick="addImageInput()" class="btn-secondary" style="margin-top: 10px; padding: 6px 12px; font-size: 10px; border-radius: 6px; cursor: pointer; background: #1a1a1a; color: #00FF87; border: 1px solid #333;">+ Add Another Picture</button>
</div>

<script>
    function addImageInput() {
        const container = document.getElementById('image-inputs-container');
        const wrapper = document.createElement('div');
        wrapper.className = 'image-input-wrapper';
        wrapper.style.display = 'flex';
        wrapper.style.gap = '10px';
        wrapper.style.alignItems = 'center';

        wrapper.innerHTML = `
            <input type="file" name="images" accept="image/*" style="flex-grow: 1;">
            <button type="button" onclick="removeImageInput(this)" style="background: transparent; border: 1px solid #ff4444; color: #ff4444; border-radius: 6px; padding: 6px 10px; cursor: pointer;">X</button>
        `;
        container.appendChild(wrapper);
    }

    function removeImageInput(button) {
        button.parentElement.remove();
    }
</script>

    <button type="submit" class="btn">Add Product</button>
</form>

    <h2>Manage Drops</h2>
    <form action="/admin/drop/add" method="POST" style="background:#1e1e1e; padding:20px; border-radius:12px; margin-bottom:30px;">
        <div style="display:grid; gap:14px; margin-bottom:16px;">
            <div class="form-group">
                <label for="theme">Drop Theme</label>
                <input type="text" id="theme" name="theme" placeholder="Summer Edition">
            </div>
            <div class="form-group">
                <label for="label">Drop Label</label>
                <input type="text" id="label" name="label" placeholder="DROP #03">
            </div>
            <div class="form-group">
                <label for="navLabel">Navigation Label</label>
                <input type="text" id="navLabel" name="navLabel" placeholder="Drop #03">
            </div>
            <div class="form-group">
                <label for="badge">Badge Text</label>
                <input type="text" id="badge" name="badge" placeholder="DROP 03 // LIMITED EDITION">
            </div>
            <div class="form-group">
                <label for="title">Hero Title</label>
                <input type="text" id="title" name="title" placeholder="Your drop title">
            </div>
            <div class="form-group">
                <label for="subtitle">Hero Subtitle</label>
                <input type="text" id="subtitle" name="subtitle" placeholder="Your drop subtitle">
            </div>
            <div class="form-group">
                <label for="totalUnits">Total Units</label>
                <input type="number" id="totalUnits" name="totalUnits" placeholder="60">
            </div>
            <div class="form-group">
                <label for="endDate">End Date</label>
                <input type="datetime-local" id="endDate" name="endDate">
            </div>
        </div>
        <button type="submit" class="btn">Create Drop</button>
    </form>

    <div style="display:flex; flex-wrap:wrap; gap:12px; align-items:center; margin-bottom:24px;">
        <form action="/admin/drop/reset" method="POST" style="margin:0;">
            <button type="submit" class="btn" style="background:#00ff87; color:#000;">Reset to Drop #01</button>
        </form>
        <span style="color:#999;">Activate Drop #01 or choose any drop below to make it live.</span>
    </div>

    <div class="drop-controls" style="display:flex; flex-wrap:wrap; gap:12px; justify-content:space-between; align-items:center; margin-bottom:20px;">
        <div style="display:flex; flex-wrap:wrap; gap:12px; align-items:center;">
            <input id="drop-search" type="text" placeholder="Search drops by label, title, theme..." style="width:260px; padding:10px 14px; border-radius:12px; border:1px solid #333; background:#121212; color:#fff;">
            <select id="drop-status-filter" style="padding:10px 14px; border-radius:12px; border:1px solid #333; background:#121212; color:#fff;">
                <option value="all">All Drops</option>
                <option value="live">Live</option>
                <option value="archived">Archived</option>
                <option value="soldout">Sold Out</option>
            </select>
            <select id="drop-page-size" style="padding:10px 14px; border-radius:12px; border:1px solid #333; background:#121212; color:#fff;">
                <option value="10">10 per page</option>
                <option value="20">20 per page</option>
                <option value="50">50 per page</option>
            </select>
        </div>
        <div style="display:flex; gap:10px; align-items:center;">
            <button type="button" id="drop-prev" class="btn" style="background:#121212; color:#00ff87; border:1px solid #00ff87;">Previous</button>
            <span id="drop-page-info" style="color:#999; font-size:13px;"></span>
            <button type="button" id="drop-next" class="btn" style="background:#121212; color:#00ff87; border:1px solid #00ff87;">Next</button>
        </div>
    </div>

    <div id="drops-grid" class="drops-grid">
        <% if (typeof drops !== 'undefined' && drops.length > 0) { %>
            <% drops.forEach(drop => { %>
                <form action="/admin/drop/update/<%= drop.id %>" method="POST" class="drop-card" data-drop-label="<%= (drop.label || '').toLowerCase() %>" data-drop-title="<%= (drop.title || '').toLowerCase() %>" data-drop-theme="<%= (drop.theme || '').toLowerCase() %>" data-drop-status="<%= drop.active ? 'live' : drop.soldOut ? 'soldout' : 'archived' %>">
                    <h3><%= drop.label %> — <%= drop.active ? 'LIVE' : 'archived' %></h3>
                    <div class="drop-fields">
                        <div class="form-group">
                            <label>Theme</label>
                            <input type="text" name="theme" value="<%= drop.theme || '' %>">
                        </div>
                        <div class="form-group">
                            <label>Label</label>
                            <input type="text" name="label" value="<%= drop.label %>" required>
                        </div>
                        <div class="form-group">
                            <label>Nav Label</label>
                            <input type="text" name="navLabel" value="<%= drop.navLabel %>" required>
                        </div>
                        <div class="form-group">
                            <label>Badge</label>
                            <input type="text" name="badge" value="<%= drop.badge %>" required>
                        </div>
                        <div class="form-group">
                            <label>Title</label>
                            <input type="text" name="title" value="<%= drop.title %>" required>
                        </div>
                        <div class="form-group">
                            <label>Subtitle</label>
                            <input type="text" name="subtitle" value="<%= drop.subtitle %>" required>
                        </div>
                        <div class="form-group">
                            <label>Total Units</label>
                            <input type="number" name="totalUnits" value="<%= drop.totalUnits %>" required>
                        </div>
                        <div class="form-group">
                            <label>Units Sold</label>
                            <input type="number" name="unitsSold" value="<%= drop.unitsSold %>" required>
                        </div>
                        <div class="form-group">
                            <label>End Date</label>
                            <input type="datetime-local" name="endDate" value="<%= drop.endDate ? drop.endDate.replace('Z', '') : '' %>" required>
                        </div>
                    </div>
                    <div class="drop-footer">
                        <label style="display:flex; align-items:center; gap:8px; font-weight:600;">
                            <input type="checkbox" name="active" value="true" <%= drop.active ? 'checked' : '' %> /> Active
                        </label>
                        <label style="display:flex; align-items:center; gap:8px; font-weight:600;">
                            <input type="checkbox" name="soldOut" value="true" <%= drop.soldOut ? 'checked' : '' %> /> Sold Out
                        </label>
                        <button type="submit" class="btn">Save Drop</button>
                    </div>
                </form>
            <% }) %>
        <% } else { %>
            <div style="color:#999;">No drops available. Create one above.</div>
        <% } %>
    </div>

    <h2>Manage Inventory</h2>
    <div class="inventory-list">
        <% if (typeof products !== 'undefined' && products.length > 0) { %>
            <% products.forEach(product => { %>
                <div class="inventory-item" style="display: flex; align-items: center; justify-content: space-between; background: #1e1e1e; padding: 10px; margin-bottom: 10px; border-radius: 6px;">
                    <img src="<%= product.imageUrl %>" width="60" alt="<%= product.name %>" style="margin-right: 10px;">
                    <div>
                        <strong><%= product.name %></strong>
                    </div>
                    <form action="/admin/delete/<%= product.id %>" method="POST" style="margin: 0;">
                        <button type="submit" class="delete-btn" style="background: #ff4757; color: #fff;">Delete</button>
                    </form>
                </div>
            <% }) %>
        <% } else { %>
            <p>No products in inventory.</p>
        <% } %>
    </div>
    
    <div id="cart-notification" class="notification">
        <div class="notification-content">
            <span class="notification-icon">⚡</span>
            <div class="notification-text">
                <span class="title">ADDED TO BAG</span>
                <span class="sub-text">Item secured. Ready for Drop #01.</span>
            </div>
        </div>
        <div class="progress-bar"></div>
    </div>

    <style>
        .notification {
            position: fixed;
            bottom: 32px;
            right: 32px;
            background: #0d0d0d;
            border: 1px solid #262626;
            border-radius: 16px;
            padding: 18px 24px;
            display: flex;
            flex-direction: column;
            gap: 8px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.8), 0 0 20px rgba(0, 255, 135, 0.15);
            z-index: 1000;
            transform: translateY(120px);
            opacity: 0;
            transition: all 0.4s cubic-bezier(0.19, 1, 0.22, 1);
            min-width: 320px;
            border-left: 4px solid #00FF87;
        }

        .notification.show {
            transform: translateY(0);
            opacity: 1;
        }

        .notification-content {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .notification-icon {
            font-size: 20px;
        }

        .notification-text {
            display: flex;
            flex-direction: column;
            gap: 2px;
        }

        .notification-text .title {
            font-family: 'Unbounded', sans-serif;
            font-size: 11px;
            font-weight: 800;
            color: #fff;
            letter-spacing: 0.5px;
        }

        .notification-text .sub-text {
            font-size: 12px;
            color: #666;
        }

        .progress-bar {
            height: 3px;
            width: 100%;
            background: #222;
            border-radius: 4px;
            overflow: hidden;
            position: relative;
        }

        .progress-bar::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            height: 100%;
            width: 100%;
            background: #00FF87;
            animation: shrink 2.5s linear forwards;
        }

        @keyframes shrink {
            0% { width: 100%; }
            100% { width: 0%; }
        }
    </style>

    <div style="margin-top: 32px;">
        <a href="/admin/orders" class="btn-orders" style="
        background: #00FF87;
        color: #000;
        padding: 14px 28px;
        text-decoration: none;
        font-weight: 800;
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        border-radius: 12px;
        display: inline-block;
        transition: all 0.3s ease;
        ">View Incoming Orders</a>
    </div>
</div>

<script>
    (function() {
        const cards = Array.from(document.querySelectorAll('#drops-grid .drop-card'));
        const searchInput = document.getElementById('drop-search');
        const statusFilter = document.getElementById('drop-status-filter');
        const pageSizeSelect = document.getElementById('drop-page-size');
        const prevButton = document.getElementById('drop-prev');
        const nextButton = document.getElementById('drop-next');
        const pageInfo = document.getElementById('drop-page-info');
        let currentPage = 1;
        let pageSize = parseInt(pageSizeSelect.value, 10);

        function getFilteredCards() {
            const query = searchInput.value.trim().toLowerCase();
            const status = statusFilter.value;
            return cards.filter(card => {
                const label = card.dataset.dropLabel || '';
                const title = card.dataset.dropTitle || '';
                const theme = card.dataset.dropTheme || '';
                const cardStatus = card.dataset.dropStatus || 'archived';

                const matchesQuery = !query || label.includes(query) || title.includes(query) || theme.includes(query);
                const matchesStatus = status === 'all' || cardStatus === status;

                return matchesQuery && matchesStatus;
            });
        }

        function renderPage() {
            const filtered = getFilteredCards();
            const totalPages = Math.max(1, Math.ceil(filtered.length / pageSize));
            if (currentPage > totalPages) currentPage = totalPages;

            cards.forEach(card => card.style.display = 'none');
            filtered.forEach((card, index) => {
                const pageIndex = Math.floor(index / pageSize) + 1;
                if (pageIndex === currentPage) {
                    card.style.display = 'block';
                }
            });

            pageInfo.textContent = `${filtered.length} drops · page ${currentPage} of ${totalPages}`;
            prevButton.disabled = currentPage <= 1;
            nextButton.disabled = currentPage >= totalPages;
        }

        function updatePageSize() {
            pageSize = parseInt(pageSizeSelect.value, 10);
            currentPage = 1;
            renderPage();
        }

        searchInput.addEventListener('input', () => {
            currentPage = 1;
            renderPage();
        });

        statusFilter.addEventListener('change', () => {
            currentPage = 1;
            renderPage();
        });

        pageSizeSelect.addEventListener('change', updatePageSize);
        prevButton.addEventListener('click', () => {
            if (currentPage > 1) {
                currentPage -= 1;
                renderPage();
            }
        });
        nextButton.addEventListener('click', () => {
            currentPage += 1;
            renderPage();
        });

        renderPage();
    })();
</script>
</body>
</html>