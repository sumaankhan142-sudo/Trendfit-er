<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Trendfit'er // Shopping Bag</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700&family=Unbounded:wght@500;800&display=swap');

        :root {
            --bg-color: #060606;
            --text-color: #ffffff;
            --accent-color: #00FF87;
            --border-color: #1a1a1a;
            --card-bg: #0f0f0f;
            --text-muted: #666666;
            --shadow-accent: 0 10px 40px rgba(0, 255, 135, 0.05);
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            font-family: 'Space Grotesk', sans-serif;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 24px 5%;
            border-bottom: 1px solid var(--border-color);
            background: rgba(6, 6, 6, 0.9);
            backdrop-filter: blur(20px);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .logo {
            font-family: 'Unbounded', sans-serif;
            font-size: 20px;
            font-weight: 800;
            letter-spacing: -1px;
            text-transform: uppercase;
        }

        .logo span { color: var(--accent-color); }
        .logo a { text-decoration: none; color: inherit; }

        .nav-links {
            display: flex;
            gap: 32px;
            font-size: 13px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 2px;
            align-items: center;
        }

        .nav-links a {
            color: var(--text-muted);
            text-decoration: none;
            transition: all 0.2s ease;
        }

        .nav-links a:hover { color: var(--text-color); }

        .cart-container {
            max-width: 1200px;
            margin: 60px auto;
            padding: 0 5%;
            display: grid;
            grid-template-columns: 1.8fr 1fr;
            gap: 40px;
            flex-grow: 1;
        }

        /* ── Titles ── */
        .section-title {
            font-family: 'Unbounded', sans-serif;
            font-size: 32px;
            font-weight: 800;
            letter-spacing: -1.5px;
            margin-bottom: 24px;
            text-transform: uppercase;
        }

        .section-title span { color: var(--accent-color); }

        .saved-title {
            font-family: 'Unbounded', sans-serif;
            font-size: 18px;
            font-weight: 800;
            letter-spacing: -0.5px;
            text-transform: uppercase;
            color: var(--text-muted);
            margin: 40px 0 16px;
            padding-top: 32px;
            border-top: 1px solid var(--border-color);
        }

        .saved-title span { color: var(--accent-color); }

        /* ── Cart Items ── */
        .cart-items-list, .wishlist-items-list {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .cart-item-refined {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            padding: 20px 24px;
            transition: all 0.3s ease;
        }

        .cart-item-refined:hover {
            border-color: #2a2a2a;
            box-shadow: var(--shadow-accent);
        }

        /* Saved items look slightly dimmed */
        .wishlist-card {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: #0a0a0a;
            border: 1px dashed #222;
            border-radius: 16px;
            padding: 16px 24px;
            transition: all 0.3s ease;
            opacity: 0.85;
        }

        .wishlist-card:hover {
            border-color: #333;
            opacity: 1;
        }

        .item-info-refined {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .item-thumb-refined {
            width: 72px;
            height: 72px;
            border-radius: 12px;
            object-fit: cover;
            background: #060606;
            border: 1px solid var(--border-color);
        }

        .item-title-refined {
            font-family: 'Unbounded', sans-serif;
            font-size: 13px;
            font-weight: 800;
            color: #fff;
            text-transform: uppercase;
            margin-bottom: 4px;
        }

        .item-price-refined {
            color: var(--accent-color);
            font-size: 15px;
            font-weight: 700;
        }

        .item-controls-refined {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .quantity-controller {
            display: flex;
            align-items: center;
            background: #060606;
            border: 1px solid var(--border-color);
            border-radius: 10px;
            padding: 2px 6px;
        }

        .qty-btn {
            background: transparent;
            border: none;
            color: #fff;
            padding: 6px 12px;
            cursor: pointer;
            font-weight: 800;
            font-size: 13px;
            transition: color 0.2s ease;
        }

        .qty-btn:hover { color: var(--accent-color); }

        .qty-display {
            padding: 0 8px;
            color: #fff;
            font-size: 13px;
            font-weight: 700;
            min-width: 16px;
            text-align: center;
        }

        .btn-action-refined {
            background: transparent;
            border: none;
            color: var(--text-muted);
            font-size: 10px;
            font-family: 'Unbounded', sans-serif;
            font-weight: 800;
            cursor: pointer;
            transition: all 0.2s ease;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .btn-action-refined:hover { color: #ff4444; }

        /* Move to Bag button */
        .btn-move-to-bag {
            background: transparent;
            border: 1px solid var(--accent-color);
            color: var(--accent-color);
            font-family: 'Unbounded', sans-serif;
            font-size: 9px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            padding: 8px 14px;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.2s ease;
            white-space: nowrap;
        }

        .btn-move-to-bag:hover {
            background: var(--accent-color);
            color: #000;
        }

        /* ── Order Summary ── */
        .summary-panel {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 20px;
            padding: 32px;
            height: fit-content;
            display: flex;
            flex-direction: column;
            gap: 24px;
            position: sticky;
            top: 90px;
        }

        .summary-title {
            font-family: 'Unbounded', sans-serif;
            font-size: 16px;
            font-weight: 800;
            letter-spacing: -0.5px;
            text-transform: uppercase;
        }

        .summary-row {
            display: flex;
            justify-content: space-between;
            color: var(--text-muted);
            font-size: 13px;
        }

        .summary-row.total {
            border-top: 1px solid var(--border-color);
            padding-top: 18px;
            font-size: 18px;
            font-family: 'Unbounded', sans-serif;
            color: #fff;
        }

        .summary-row.total .price { color: var(--accent-color); }

        .checkout-btn {
            background: var(--accent-color);
            color: #000;
            font-family: 'Unbounded', sans-serif;
            font-size: 11px;
            font-weight: 800;
            text-transform: uppercase;
            padding: 18px 20px;
            border-radius: 12px;
            border: none;
            cursor: pointer;
            text-align: center;
            text-decoration: none;
            transition: all 0.3s ease;
            letter-spacing: 1px;
            display: flex;
            justify-content: center;
            align-items: center;
            width: 100%;
            height: 52px;
        }

        .checkout-btn:hover {
            background: #ffffff;
            box-shadow: 0 0 25px rgba(0, 255, 135, 0.3);
            transform: translateY(-2px);
        }

        .empty-text {
            color: var(--text-muted);
            text-align: center;
            padding: 60px 0;
            font-size: 14px;
        }

        @media (max-width: 968px) {
            .cart-container { grid-template-columns: 1fr; }
            .cart-item-refined, .wishlist-card {
                flex-direction: column;
                align-items: flex-start;
                gap: 16px;
            }
            .item-controls-refined { width: 100%; justify-content: space-between; }
        }
    </style>
</head>
<body>

<header>
    <div class="logo"><a href="/">Trend<span>fit'er</span></a></div>
    <div class="nav-links">
        <a href="/">Shop</a>
    </div>
</header>

<main class="cart-container">
    <div class="cart-column">

        <!-- ── SHOPPING BAG ── -->
        <h1 class="section-title">Shopping <span>Bag</span></h1>

        <div class="cart-items-list">
            <% if (typeof cartItems !== 'undefined' && cartItems.length > 0) { %>
                <% cartItems.forEach(item => { %>
                    <div class="cart-item-refined" id="cart-item-<%= item.id %>">
                        <div class="item-info-refined">
                            <img src="<%= item.imageUrl %>" alt="<%= item.name %>" class="item-thumb-refined">
                            <div>
                                <div class="item-title-refined"><%= item.name %></div>
                                <div class="item-price-refined">PKR <%= item.price %></div>
                            </div>
                        </div>

                        <div class="item-controls-refined">
                            <div class="quantity-controller">
                                <form action="/cart/update/<%= item.id %>?action=decrease" method="POST" style="margin:0;">
                                    <button class="qty-btn" type="submit">-</button>
                                </form>
                                <span class="qty-display"><%= item.quantity || 1 %></span>
                                <form action="/cart/update/<%= item.id %>?action=increase" method="POST" style="margin:0;">
                                    <button class="qty-btn" type="submit">+</button>
                                </form>
                            </div>
                            <button onclick="moveToWishlist('<%= item.id %>')" class="btn-action-refined">Save Later</button>
                            <button onclick="removeItem('<%= item.id %>')" class="btn-action-refined">Remove</button>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="empty-text">Your Shopping Bag is empty.</div>
            <% } %>
        </div>

        <!-- ── SAVED FOR LATER ── -->
        <% if (typeof wishlistItems !== 'undefined' && wishlistItems.length > 0) { %>
            <h2 class="saved-title">Saved for <span>Later</span> (<%= wishlistItems.length %>)</h2>
            <div class="wishlist-items-list">
                <% wishlistItems.forEach(item => { %>
                    <div class="wishlist-card" id="wish-<%= item.id %>">
                        <div class="item-info-refined">
                            <img src="<%= item.imageUrl %>" alt="<%= item.name %>" class="item-thumb-refined">
                            <div>
                                <div class="item-title-refined"><%= item.name %></div>
                                <div class="item-price-refined">PKR <%= item.price %></div>
                            </div>
                        </div>
                        <div class="item-controls-refined">
                            <button onclick="moveToBag('<%= item.id %>')" class="btn-move-to-bag">Move to Bag</button>
                            <button onclick="removeFromWishlist('<%= item.id %>')" class="btn-action-refined">Remove</button>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>

    </div>

    <!-- ── ORDER SUMMARY ── -->
    <div class="summary-column">
        <div class="summary-panel">
            <h2 class="summary-title">Order Summary</h2>

            <div class="summary-row">
                <span>Items</span>
                <span>PKR <%= typeof cartItems !== 'undefined' ? cartItems.reduce((acc, item) => acc + (item.price * (item.quantity || 1)), 0) : 0 %></span>
            </div>

            <div class="summary-row">
                <span>Shipping</span>
                <span>Free</span>
            </div>

            <div class="summary-row total">
                <span>Total</span>
                <span class="price">PKR <%= typeof cartItems !== 'undefined' ? cartItems.reduce((acc, item) => acc + (item.price * (item.quantity || 1)), 0) : 0 %></span>
            </div>

            <a href="/checkout" class="checkout-btn">Proceed to Checkout</a>
        </div>
    </div>
</main>

<script>
    async function moveToWishlist(itemId) {
        try {
            const res = await fetch(`/cart/wishlist/${itemId}`, { method: 'POST' });
            const data = await res.json();
            if (data.success) window.location.reload();
        } catch (err) { console.error(err); }
    }

    async function removeItem(itemId) {
        try {
            const res = await fetch(`/cart/remove/${itemId}`, { method: 'POST' });
            const data = await res.json();
            if (data.success) window.location.reload();
        } catch (err) { console.error(err); }
    }

    async function moveToBag(itemId) {
        try {
            const res = await fetch(`/wishlist/move-to-cart/${itemId}`, { method: 'POST' });
            const data = await res.json();
            if (data.success) window.location.reload();
        } catch (err) { console.error(err); }
    }

    async function removeFromWishlist(itemId) {
        try {
            const res = await fetch(`/wishlist/remove/${itemId}`, { method: 'POST' });
            const data = await res.json();
            if (data.success) window.location.reload();
        } catch (err) { console.error(err); }
    }
</script>
</body>
</html>