<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Trendfit'er // Saved Items</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700&family=Unbounded:wght@500;800&display=swap');

        :root {
            --bg-color: #060606;
            --text-color: #ffffff;
            --accent-color: #00FF87;
            --border-color: #1a1a1a;
            --card-bg: #0f0f0f;
            --text-muted: #666666;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            font-family: 'Space Grotesk', sans-serif;
            min-height: 100vh;
        }

        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 24px 5%;
            border-bottom: 1px solid var(--border-color);
            background: rgba(6,6,6,0.9);
            backdrop-filter: blur(20px);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .logo {
            font-family: 'Unbounded', sans-serif;
            font-size: 20px;
            font-weight: 800;
            letter-spacing: -1px;
            text-transform: uppercase;
        }

        .logo span { color: var(--accent-color); }
        .logo a { text-decoration: none; color: inherit; }

        .nav-links {
            display: flex;
            gap: 32px;
            font-size: 13px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .nav-links a {
            color: var(--text-muted);
            text-decoration: none;
            transition: all 0.2s ease;
        }

        .nav-links a:hover { color: #fff; }

        .page-container {
            max-width: 900px;
            margin: 60px auto;
            padding: 0 5%;
        }

        .page-title {
            font-family: 'Unbounded', sans-serif;
            font-size: 32px;
            font-weight: 800;
            letter-spacing: -1.5px;
            margin-bottom: 32px;
            text-transform: uppercase;
        }

        .page-title span { color: var(--accent-color); }

        .wishlist-list {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .wishlist-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            padding: 20px 24px;
            transition: all 0.3s ease;
        }

        .wishlist-item:hover {
            border-color: #2a2a2a;
            box-shadow: 0 10px 40px rgba(0,255,135,0.05);
        }

        .item-info {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .item-thumb {
            width: 72px;
            height: 72px;
            border-radius: 12px;
            object-fit: cover;
            border: 1px solid var(--border-color);
            background: #060606;
        }

        .item-name {
            font-family: 'Unbounded', sans-serif;
            font-size: 13px;
            font-weight: 800;
            text-transform: uppercase;
            margin-bottom: 4px;
        }

        .item-price {
            color: var(--accent-color);
            font-size: 15px;
            font-weight: 700;
        }

        .item-actions {
            display: flex;
            gap: 16px;
            align-items: center;
        }

        .btn-move {
            background: var(--accent-color);
            color: #000;
            font-family: 'Unbounded', sans-serif;
            font-size: 10px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            padding: 10px 18px;
            border-radius: 8px;
            border: none;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .btn-move:hover {
            background: #fff;
            box-shadow: 0 0 20px rgba(0,255,135,0.2);
        }

        .btn-remove {
            background: transparent;
            border: none;
            color: var(--text-muted);
            font-family: 'Unbounded', sans-serif;
            font-size: 10px;
            font-weight: 800;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .btn-remove:hover {
            color: #ff4444;
        }

        .empty-text {
            color: var(--text-muted);
            text-align: center;
            padding: 80px 0;
            font-size: 14px;
        }

        .empty-text a {
            color: var(--accent-color);
            text-decoration: none;
        }
    </style>
</head>
<body>

    <header>
        <div class="logo"><a href="/">Trend<span>fit'er</span></a></div>
        <div class="nav-links">
            <a href="/">Shop</a>
            <a href="/cart">Bag</a>
        </div>
    </header>

    <main class="page-container">
        <h1 class="page-title">Saved <span>Items</span></h1>

        <div class="wishlist-list">
            <% if (wishlistItems && wishlistItems.length > 0) { %>
                <% wishlistItems.forEach(item => { %>
                    <div class="wishlist-item" id="wish-<%= item.id %>">
                        <div class="item-info">
                            <img src="<%= item.imageUrl %>" alt="<%= item.name %>" class="item-thumb">
                            <div>
                                <div class="item-name"><%= item.name %></div>
                                <div class="item-price">PKR <%= item.price %></div>
                            </div>
                        </div>
                        <div class="item-actions">
                            <button class="btn-move" onclick="moveToCart('<%= item.id %>')">Move to Bag</button>
                            <button class="btn-remove" onclick="removeFromWishlist('<%= item.id %>')">Remove</button>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="empty-text">
                    No saved items yet. <a href="/">Continue Shopping</a>
                </div>
            <% } %>
        </div>
    </main>

    <script>
        async function moveToCart(itemId) {
            const res = await fetch(`/wishlist/move-to-cart/${itemId}`, { method: 'POST' });
            const data = await res.json();
            if (data.success) {
                document.getElementById(`wish-${itemId}`).remove();
                // If list is empty now, reload to show empty state
                if (document.querySelectorAll('.wishlist-item').length === 0) {
                    window.location.reload();
                }
            }
        }

        async function removeFromWishlist(itemId) {
            const res = await fetch(`/wishlist/remove/${itemId}`, { method: 'POST' });
            const data = await res.json();
            if (data.success) {
                document.getElementById(`wish-${itemId}`).remove();
                if (document.querySelectorAll('.wishlist-item').length === 0) {
                    window.location.reload();
                }
            }
        }
    </script>
</body>
</html>