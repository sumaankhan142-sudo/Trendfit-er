<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Trendfit'er // <%= activeDrop ? activeDrop.label : 'Drop #01' %></title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700&family=Unbounded:wght@500;800&display=swap');

        :root {
            --bg-color: #060606;
            --text-color: #ffffff;
            --accent-color: #00FF87;
            --secondary-color: #1ed760;
            --card-bg: #0f0f0f;
            --border-color: #1a1a1a;
            --card-border: #2a2a2a;
            --text-muted: #666666;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }
        html { scroll-behavior: smooth; }

        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            font-family: 'Space Grotesk', sans-serif;
            overflow-x: hidden;
            padding: 0;
        }

        /* ── HEADER (unchanged) ─────────────────────────────── */
        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 36px 5%;
            border-bottom: 1px solid var(--border-color);
            background: rgba(6, 6, 6, 0.9);
            backdrop-filter: blur(20px);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .logo {
            font-family: 'Unbounded', sans-serif;
            font-size: 24px;
            font-weight: 800;
            letter-spacing: -1px;
            text-transform: uppercase;
        }

        .logo span { color: var(--accent-color); }

        .nav-links {
            display: flex;
            gap: 32px;
            font-size: 13px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 2px;
            align-items: center;
        }

        .nav-links a {
            color: var(--text-muted);
            text-decoration: none;
            transition: all 0.2s ease;
        }

        .nav-links a:hover {
            color: var(--text-color);
            text-shadow: 0 0 8px var(--accent-color);
        }

        .nav-cart-btn {
            background: transparent;
            border: 1px solid var(--border-color);
            cursor: pointer;
            color: var(--text-color);
            display: flex;
            align-items: center;
            justify-content: center;
            width: 44px;
            height: 44px;
            border-radius: 50%;
            transition: all 0.3s ease;
            position: relative;
        }

        .nav-cart-btn:hover {
            border-color: var(--accent-color);
            box-shadow: 0 0 15px rgba(0, 255, 135, 0.2);
            transform: translateY(-2px);
        }

        .nav-cart-btn svg {
            width: 16px;
            height: 16px;
            fill: none;
            stroke: var(--text-color);
            stroke-width: 2;
        }

        .cart-badge {
            position: absolute;
            top: -6px;
            right: -6px;
            background: var(--accent-color);
            color: #000;
            font-size: 9px;
            font-weight: 800;
            padding: 2px 6px;
            border-radius: 10px;
            letter-spacing: 0.5px;
            box-shadow: 0 0 10px rgba(0, 255, 135, 0.4);
        }

        /* ── HERO ───────────────────────────────────────────── */
        .hero {
            padding: 52px 5% 20px;
            text-align: center;
            max-width: 900px;
            margin: 0 auto;
        }

        .hero h1 {
            font-family: 'Unbounded', sans-serif;
            font-size: 5vw;
            font-weight: 800;
            line-height: 0.85;
            letter-spacing: -2px;
            margin-bottom: 14px;
            text-transform: uppercase;
            background: linear-gradient(180deg, #FFFFFF 0%, #666666 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .hero p {
            color: var(--text-muted);
            font-size: 16px;
            max-width: 500px;
            margin: 0 auto 14px;
            line-height: 1.5;
            font-weight: 500;
        }

        .drop-tag {
            display: inline-block;
            background: var(--accent-color);
            color: #000;
            font-size: 10px;
            font-weight: 800;
            padding: 6px 16px;
            border-radius: 30px;
            letter-spacing: 2px;
            text-transform: uppercase;
            margin-bottom: 24px;
            transform: rotate(-2deg);
        }

        /* ── DROP DOTS (which drop is live) ─────────────────── */
        .drop-dots-row {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            margin-top: 14px;
        }

        .drop-dot {
            width: 9px;
            height: 9px;
            border-radius: 50%;
            transition: all 0.3s ease;
        }

        .drop-dot.active   { background: var(--accent-color); box-shadow: 0 0 8px var(--accent-color); border: 2px solid var(--accent-color); }
        .drop-dot.sold     { background: #2a2a2a; border: 2px solid #2a2a2a; }
        .drop-dot.upcoming { background: transparent; border: 2px solid #2a2a2a; }

        .drop-dot-label {
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 2px;
            color: var(--accent-color);
            text-transform: uppercase;
            margin-left: 6px;
        }

        .hero-theme {
            margin: 14px auto 0;
            display: inline-block;
            font-size: 12px;
            color: #00ff87;
            letter-spacing: 1px;
            text-transform: uppercase;
            font-weight: 700;
        }

        /* ── FOMO STRIP (countdown + units) ─────────────────── */
        .fomo-strip {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0;
            max-width: 860px;
            margin: 12px auto 0;
            background: #0a0a0a;
            border: 1px solid var(--border-color);
            border-radius: 20px;
            overflow: hidden;
        }

        .fomo-block {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 10px;
            padding: 22px 40px;
        }

        .fomo-divider {
            width: 1px;
            height: 80px;
            background: var(--border-color);
            flex-shrink: 0;
        }

        .fomo-label {
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 2.5px;
            color: var(--text-muted);
            text-transform: uppercase;
        }

        /* Countdown */
        .countdown-row {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .time-box {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
        }

        .time-num {
            font-family: 'Unbounded', sans-serif;
            font-size: 34px;
            font-weight: 800;
            color: #fff;
            line-height: 1;
            letter-spacing: -1px;
            min-width: 50px;
            text-align: center;
            font-variant-numeric: tabular-nums;
        }

        .time-unit {
            font-size: 9px;
            font-weight: 700;
            letter-spacing: 2px;
            color: #333;
            text-transform: uppercase;
        }

        .time-colon {
            font-family: 'Unbounded', sans-serif;
            font-size: 26px;
            font-weight: 800;
            color: #2a2a2a;
            margin-bottom: 14px;
        }

        /* Units bar */
        .units-num {
            font-family: 'Unbounded', sans-serif;
            font-size: 22px;
            font-weight: 800;
            color: #fff;
            letter-spacing: -0.5px;
        }

        .units-num.urgent { color: var(--accent-color); }

        .units-bar-track {
            width: 220px;
            height: 5px;
            background: #1a1a1a;
            border-radius: 4px;
            overflow: hidden;
        }

        .units-bar-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--accent-color), #1aff1a);
            border-radius: 4px;
            transition: width 0.6s ease;
        }

        .units-bar-fill.urgent {
            box-shadow: 0 0 8px rgba(0, 255, 135, 0.5);
        }

        .units-pct {
            font-size: 10px;
            font-weight: 700;
            color: #333;
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        /* Sold out state */
        .units-soldout {
            font-family: 'Unbounded', sans-serif;
            font-size: 22px;
            font-weight: 800;
            color: #333;
            letter-spacing: -1px;
        }

        /* ── WAITLIST SECTION ────────────────────────────────── */
        .waitlist-section {
            max-width: 860px;
            margin: 10px auto 0;
            background: #080808;
            border: 1px solid var(--border-color);
            border-radius: 20px;
            padding: 24px 32px;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 32px;
            align-items: center;
        }

        .waitlist-eyebrow {
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 3px;
            color: var(--accent-color);
            text-transform: uppercase;
            margin-bottom: 10px;
        }

        .waitlist-title {
            font-family: 'Unbounded', sans-serif;
            font-size: 22px;
            font-weight: 800;
            letter-spacing: -1px;
            line-height: 1;
            color: #fff;
            margin-bottom: 10px;
        }

        .waitlist-sub {
            font-size: 13px;
            color: var(--text-muted);
            line-height: 1.6;
        }

        .waitlist-inputs {
            display: flex;
            flex-direction: column;
            gap: 10px;
            margin-bottom: 14px;
        }

        .waitlist-input {
            width: 100%;
            background: #0a0a0a;
            border: 1px solid rgba(0, 255, 135, 0.25);
            border-radius: 12px;
            padding: 14px 18px;
            color: #fff;
            font-family: 'Space Grotesk', sans-serif;
            font-size: 13px;
            font-weight: 500;
            outline: none;
            transition: all 0.2s ease;
            box-sizing: border-box;
            box-shadow: 0 0 0 0 rgba(0, 255, 135, 0);
        }

        .waitlist-input:focus {
            border-color: var(--accent-color);
            box-shadow: 0 0 12px rgba(0, 255, 135, 0.12);
            background: #0d0d0d;
        }

        .waitlist-input::placeholder {
            color: rgba(0, 255, 135, 0.3);
            font-family: 'Space Grotesk', sans-serif;
            font-size: 12px;
            letter-spacing: 0.5px;
        }

        .waitlist-error {
            font-size: 11px;
            color: #ff4444;
            margin-bottom: 8px;
            display: none;
        }

        .waitlist-btn {
            width: 100%;
            background: var(--accent-color);
            color: #000;
            font-family: 'Unbounded', sans-serif;
            font-size: 10px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            padding: 15px 20px;
            border-radius: 12px;
            border: none;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .waitlist-btn:hover {
            background: #fff;
            box-shadow: 0 0 24px rgba(0, 255, 135, 0.25);
            transform: translateY(-2px);
        }

        .waitlist-btn:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }

        .waitlist-success {
            display: none;
            align-items: flex-start;
            gap: 14px;
            padding: 18px;
            background: rgba(0, 255, 135, 0.05);
            border: 1px solid rgba(0, 255, 135, 0.15);
            border-radius: 14px;
        }

        .waitlist-success-check {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: var(--accent-color);
            color: #000;
            font-size: 16px;
            font-weight: 800;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .waitlist-success-title {
            font-family: 'Unbounded', sans-serif;
            font-size: 11px;
            font-weight: 800;
            color: var(--accent-color);
            letter-spacing: 1px;
            margin-bottom: 4px;
        }

        .waitlist-success-sub {
            font-size: 12px;
            color: var(--text-muted);
            line-height: 1.5;
        }

        /* ── ARCHIVE STRIP ───────────────────────────────────── */
        .archive-section {
            max-width: 860px;
            margin: 10px auto 0;
            padding: 0 0 8px;
        }

        .archive-label {
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 3px;
            color: #2a2a2a;
            text-transform: uppercase;
            padding-bottom: 12px;
            border-bottom: 1px solid #111;
            margin-bottom: 12px;
        }

        .archive-list {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .archive-item {
            display: flex;
            align-items: center;
            gap: 20px;
            padding: 12px 18px;
            background: #070707;
            border: 1px solid #111;
            border-radius: 10px;
        }

        .archive-item-label {
            font-family: 'Unbounded', sans-serif;
            font-size: 9px;
            font-weight: 800;
            color: #2a2a2a;
            letter-spacing: 1px;
            min-width: 80px;
        }

        .archive-item-title {
            font-size: 12px;
            color: #333;
            flex: 1;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .archive-item-sold {
            font-size: 9px;
            font-weight: 700;
            color: #2a2a2a;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        /* ── PRODUCTS GRID ──────────────────────────────────── */
        .products-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 28px 5% 80px;
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
            gap: 32px;
            justify-items: center;
        }

        /* When only 1 product - center it and limit width so it doesn't look abandoned */
        .products-container.single-product {
            grid-template-columns: minmax(320px, 480px);
            justify-content: center;
        }

        /* When 2 products */
        .products-container.two-products {
            grid-template-columns: repeat(2, minmax(320px, 500px));
            justify-content: center;
        }

        .product-card {
            background-color: var(--card-bg);
            border: 1px solid var(--card-border);
            border-radius: 24px;
            overflow: hidden;
            transition: all 0.4s cubic-bezier(0.19, 1, 0.22, 1);
            display: flex;
            flex-direction: column;
            position: relative;
        }

        .product-card:hover {
            transform: translateY(-8px) scale(1.01);
            border-color: var(--accent-color);
            box-shadow: 0 0 40px rgba(0, 255, 135, 0.1);
        }

        .product-img-wrapper {
            position: relative;
            width: 100%;
            height: 420px;
            overflow: hidden;
        }

        .product-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.6s cubic-bezier(0.19, 1, 0.22, 1);
        }

        .product-card:hover .product-img { transform: scale(1.06); }

        .badge {
            position: absolute;
            top: 20px;
            left: 20px;
            background: var(--accent-color);
            color: #000;
            font-size: 10px;
            font-weight: 800;
            padding: 6px 14px;
            border-radius: 30px;
            letter-spacing: 1.5px;
            text-transform: uppercase;
        }

        .wishlist-btn {
            position: absolute;
            top: 20px;
            right: 20px;
            background: rgba(0, 0, 0, 0.7);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .wishlist-btn:hover { background: var(--text-color); transform: scale(1.1); }

        .wishlist-btn svg {
            width: 16px;
            height: 16px;
            fill: none;
            stroke: var(--text-color);
            stroke-width: 2.5;
            transition: stroke 0.2s ease;
        }

        .wishlist-btn:hover svg { stroke: #000; }

        .product-info {
            padding: 28px;
            display: flex;
            flex-direction: column;
            flex-grow: 1;
        }

        .product-title {
            font-family: 'Unbounded', sans-serif;
            font-size: 18px;
            font-weight: 500;
            margin-bottom: 12px;
            letter-spacing: -0.5px;
        }

        .product-description {
            color: var(--text-muted);
            font-size: 13px;
            line-height: 1.6;
            margin-bottom: 28px;
            flex-grow: 1;
            font-weight: 500;
        }

        .product-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-top: 20px;
            border-top: 1px solid rgba(255, 255, 255, 0.04);
        }

        .product-price {
            font-family: 'Unbounded', sans-serif;
            font-size: 20px;
            font-weight: 800;
            letter-spacing: -1px;
        }

        .btn-group { display: flex; gap: 10px; }

        .cart-btn, .buy-btn {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            padding: 12px 16px;
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.19, 1, 0.22, 1);
            text-decoration: none;
            text-align: center;
            border: none;
        }

        .cart-btn {
            background: #0e0e0e;
            color: var(--accent-color);
            border: 1px solid var(--accent-color);
        }

        .cart-btn:hover {
            background: var(--accent-color);
            color: #000;
            transform: translateY(-2px);
            box-shadow: 0 0 20px rgba(0, 255, 135, 0.3);
        }

        .buy-btn { background: var(--accent-color); color: #000; }

        .buy-btn:hover {
            background: #fff;
            transform: translateY(-2px);
            box-shadow: 0 0 20px rgba(0, 255, 135, 0.4);
        }

        .empty-state {
            grid-column: 1 / -1;
            text-align: center;
            padding: 60px 20px;
            color: var(--text-muted);
        }

        .empty-state h3 {
            font-family: 'Unbounded', sans-serif;
            font-size: 16px;
            margin-bottom: 8px;
            color: #333;
            letter-spacing: -0.5px;
        }

        .empty-state p {
            font-size: 13px;
            color: #2a2a2a;
        }

        /* ── NOTIFICATION (unchanged) ───────────────────────── */
        .notification {
            position: fixed;
            bottom: 32px;
            right: 32px;
            background: #0d0d0d;
            border: 1px solid #262626;
            border-radius: 16px;
            padding: 18px 24px;
            display: flex;
            flex-direction: column;
            gap: 8px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.8), 0 0 20px rgba(0,255,135,0.15);
            z-index: 1000;
            transform: translateY(120px);
            opacity: 0;
            transition: all 0.4s cubic-bezier(0.19, 1, 0.22, 1);
            min-width: 320px;
            border-left: 4px solid #00FF87;
        }

        .notification.show { transform: translateY(0); opacity: 1; }

        .notification-content { display: flex; align-items: center; gap: 16px; }
        .notification-icon { font-size: 20px; }

        .notification-text { display: flex; flex-direction: column; gap: 2px; }

        .notification-text .title {
            font-family: 'Unbounded', sans-serif;
            font-size: 11px;
            font-weight: 800;
            color: #fff;
            letter-spacing: 0.5px;
        }

        .notification-text .sub-text { font-size: 12px; color: #666; }

        .progress-bar {
            height: 3px;
            width: 100%;
            background: #222;
            border-radius: 4px;
            overflow: hidden;
            position: relative;
        }

        .progress-bar::after {
            content: '';
            position: absolute;
            top: 0; left: 0;
            height: 100%; width: 100%;
            background: #00FF87;
            animation: shrink 2.5s linear forwards;
        }

        @keyframes shrink {
            0%   { width: 100%; }
            100% { width: 0%; }
        }

        /* ── RESPONSIVE ─────────────────────────────────────── */
        @media (max-width: 768px) {
            .hero { padding: 40px 5% 20px; }
            .fomo-strip { flex-direction: column; gap: 0; }
            .fomo-block { padding: 20px 24px; width: 100%; }
            .fomo-divider { width: 100%; height: 1px; }
            .time-num { font-size: 26px; min-width: 38px; }
            .waitlist-section { grid-template-columns: 1fr; gap: 20px; padding: 24px 20px; margin: 12px auto 0; }
            .waitlist-title { font-size: 20px; }
            .archive-item { flex-direction: column; align-items: flex-start; gap: 4px; }
            .hero h1 { font-size: 9vw; }
        }
    </style>
</head>
<body>

<!-- ════════════════════════════════════════════════════════ -->
<!--  HEADER                                                 -->
<!-- ════════════════════════════════════════════════════════ -->
<header>
    <div class="logo">Trend<span>fit'er</span></div>
    <div class="nav-links">
        <a href="/">Home</a>
        <!-- Nav label updates automatically from active drop -->
        <a href="#drop-section"><%= activeDrop ? activeDrop.navLabel || activeDrop.label : 'Drop #01' %></a>
        <button class="nav-cart-btn" onclick="goToCart()" title="Your Cart">
            <svg viewBox="0 0 24 24">
                <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4zM3 6h18M16 10a4 4 0 0 1-8 0"/>
            </svg>
            <span id="cart-count" class="cart-badge" style="display:none;">0</span>
        </button>
    </div>
</header>


<!-- ════════════════════════════════════════════════════════ -->
<!--  HERO — title + badge pulled from drops.config.js       -->
<!-- ════════════════════════════════════════════════════════ -->
<% const drop = activeDrop; %>
<% const unitsLeft = drop ? drop.totalUnits - drop.unitsSold : 0; %>
<% const pctClaimed = drop ? Math.round((drop.unitsSold / drop.totalUnits) * 100) : 0; %>
<% const isUrgent = unitsLeft <= 10 && !drop.soldOut; %>

<section class="hero">
    <!-- Badge — auto from config -->
    <div class="drop-tag"><%= drop ? drop.badge : 'DROP 01 // LIMITED EDITION' %></div>

    <% if (drop && drop.theme) { %>
        <div class="hero-theme">Theme: <%= drop.theme %></div>
    <% } %>

    <!-- Title — auto from config -->
    <h1><%= drop ? drop.title : 'ZERO-FRICTION STREETWEAR' %></h1>

    <!-- Subtitle — auto from config -->
    <p><%= drop ? drop.subtitle : 'Engineered to exist at the intersection of the underground and high performance.' %></p>

    <!-- Drop progress dots -->
    <% if (drops && drops.length > 1) { %>
    <div class="drop-dots-row">
        <% drops.forEach(function(d) { %>
            <div class="drop-dot <%= d.active ? 'active' : d.soldOut ? 'sold' : 'upcoming' %>"
                 title="<%= d.label %>"></div>
        <% }) %>
        <span class="drop-dot-label"><%= drop ? drop.label : '' %> LIVE</span>
    </div>
    <% } %>
</section>

<!-- ════════════════════════════════════════════════════════ -->
<!--  COUNTDOWN TIMER: Right under hero (creates urgency)    -->
<!-- ════════════════════════════════════════════════════════ -->
<% if (drop && !drop.soldOut) { %>
<div style="max-width:860px; margin: 0 auto 60px; padding: 0 5%;">
    <div class="fomo-strip">
        <div class="fomo-block">
            <div class="fomo-label">Drop closes in</div>
            <div class="countdown-row" id="countdown" data-end="<%= drop.endDate %>">
                <div class="time-box"><span class="time-num" id="cd-days">00</span><span class="time-unit">Days</span></div>
                <span class="time-colon">:</span>
                <div class="time-box"><span class="time-num" id="cd-hours">00</span><span class="time-unit">Hrs</span></div>
                <span class="time-colon">:</span>
                <div class="time-box"><span class="time-num" id="cd-mins">00</span><span class="time-unit">Min</span></div>
                <span class="time-colon">:</span>
                <div class="time-box"><span class="time-num" id="cd-secs">00</span><span class="time-unit">Sec</span></div>
            </div>
        </div>
    </div>
</div>
<% } else if (drop && drop.soldOut) { %>
<div style="max-width:860px; margin: 0 auto 60px; padding: 0 5%;">
    <div class="fomo-strip">
        <div class="fomo-block">
            <div class="fomo-label">Drop Status</div>
            <div style="font-family:'Unbounded',sans-serif; font-size:18px; font-weight:800; color:#333; letter-spacing:-0.5px;">DROP CLOSED</div>
        </div>
    </div>
</div>
<% } %>



<!-- ════════════════════════════════════════════════════════ -->
<!--  PRODUCTS: What they're buying NOW                      -->
<!-- ════════════════════════════════════════════════════════ -->
<div id="drop-section" class="products-container <%= products.length === 1 ? 'single-product' : products.length === 2 ? 'two-products' : '' %>">
    <% if (products.length === 0) { %>
        <div class="empty-state">
            <h3>Loading Drop Items</h3>
            <p>Add products via the admin panel to populate this drop.</p>
        </div>
    <% } else { %>
        <% products.forEach(product => { %>
            <div class="product-card" style="width:100%; cursor:pointer;" onclick="window.location.href='/product/<%= product.id %>'">
                <div class="product-img-wrapper">
                    <div class="badge">Limited</div>
                    <button class="wishlist-btn" onclick="event.preventDefault(); event.stopPropagation(); alert('Saved!')" title="Save to Wishlist">
                        <svg viewBox="0 0 24 24">
                            <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
                        </svg>
                    </button>
                    <% let imageSrc = product.imageUrls && product.imageUrls.length > 0 ? product.imageUrls[0] : product.imageUrl; %>
                    <img class="product-img" src="<%= imageSrc %>" alt="<%= product.name %>">
                </div>
                <div class="product-info">
                    <h3 class="product-title"><%= product.name.toUpperCase() %></h3>
                    <p class="product-description"><%= product.description %></p>
                    <div class="product-footer">
                        <div class="product-price">PKR <%= product.price %></div>
                        <div class="btn-group">
                            <button type="button" class="cart-btn" onclick="event.stopPropagation(); addToBag('<%= product.id %>');">ADD TO BAG</button>
                            <form action="/buy/<%= product.id %>" method="POST" style="margin:0;" onsubmit="event.stopPropagation();">
                                <button type="submit" class="buy-btn" onclick="event.stopPropagation();">BUY NOW</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        <% }) %>
    <% } %>
</div>

<!-- ════════════════════════════════════════════════════════ -->
<!--  SCARCITY HITS: Units remaining bar (after products)    -->
<!-- ════════════════════════════════════════════════════════ -->
<% if (drop) { %>
    <% const unitsLeft = drop.totalUnits - drop.unitsSold; %>
    <% const pctClaimed = Math.round((drop.unitsSold / drop.totalUnits) * 100); %>
    <% const isUrgent = unitsLeft <= 10 && !drop.soldOut; %>
    
    <div style="max-width:860px; margin: 0 auto 60px; padding: 0 5%;">
        <div style="background: #0a0a0a; border: 1px solid var(--border-color); border-radius: 20px; padding: 32px 40px; text-align: center;">
            <div style="font-size: 10px; font-weight: 700; letter-spacing: 2.5px; color: var(--text-muted); text-transform: uppercase; margin-bottom: 16px;">Units Remaining</div>
            <% if (drop.soldOut) { %>
                <div style="font-family:'Unbounded',sans-serif; font-size:24px; font-weight:800; color:#333; letter-spacing:-1px; margin-bottom:16px;">SOLD OUT</div>
                <div style="width:100%; max-width:340px; height:6px; background:#1a1a1a; border-radius:4px; overflow:hidden; margin:0 auto 12px;">
                    <div style="height:100%; width:100%; background:#1a1a1a;"></div>
                </div>
                <div style="font-size:10px; font-weight:700; color:#333; letter-spacing:1px; text-transform:uppercase;"><%= drop.totalUnits %> / <%= drop.totalUnits %> claimed</div>
            <% } else { %>
                <div style="font-family:'Unbounded',sans-serif; font-size:26px; font-weight:800; color:<%= isUrgent ? 'var(--accent-color)' : '#fff' %>; letter-spacing:-0.5px; margin-bottom:16px;">
                    <% if (isUrgent) { %>⚡ <% } %><%= unitsLeft %> / <%= drop.totalUnits %> left
                </div>
                <div style="width:100%; max-width:340px; height:6px; background:#1a1a1a; border-radius:4px; overflow:hidden; margin:0 auto 12px; <%= isUrgent ? 'box-shadow:0 0 12px rgba(0,255,135,0.6);' : '' %>">
                    <div style="height:100%; background:linear-gradient(90deg, var(--accent-color), #1aff1a); border-radius:4px; width:<%= pctClaimed %>%;"></div>
                </div>
                <div style="font-size:10px; font-weight:700; color:#333; letter-spacing:1px; text-transform:uppercase;"><%= pctClaimed %>% claimed</div>
            <% } %>
        </div>
    </div>
<% } %>

<!-- ════════════════════════════════════════════════════════ -->
<!--  WAITLIST: FOMO + Next drop (after products hit)        -->
<!-- ════════════════════════════════════════════════════════ -->
<div style="max-width:860px; margin: 0 auto 60px; padding: 0 5%;">
    <div style="background: #080808; border: 1px solid var(--border-color); border-radius: 20px; padding: 32px; display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: center;">
        <div>
            <div style="font-size:10px; font-weight:700; letter-spacing:3px; color:var(--accent-color); text-transform:uppercase; margin-bottom:10px;">Next Drop</div>
            <h2 style="font-family:'Unbounded',sans-serif; font-size:28px; font-weight:800; letter-spacing:-1px; line-height:1.1; color:#fff; margin-bottom:14px;">Be first.<br>Not sorry.</h2>
            <p style="font-size:13px; color:var(--text-muted); line-height:1.6;">Drop closes. List gets hit first.<br>No second chances.</p>
        </div>
        <div>
            <div id="wl-form">
                <div style="display:flex; flex-direction:column; gap:10px; margin-bottom:14px;">
                    <input type="email" id="wl-email" style="width:100%; background:#0a0a0a; border:1px solid rgba(0,255,135,0.25); border-radius:12px; padding:14px 18px; color:#fff; font-family:'Space Grotesk',sans-serif; font-size:13px; font-weight:500; outline:none; box-sizing:border-box;" placeholder="your@email.com" autocomplete="email">
                    <input type="tel" id="wl-phone" style="width:100%; background:#0a0a0a; border:1px solid rgba(0,255,135,0.25); border-radius:12px; padding:14px 18px; color:#fff; font-family:'Space Grotesk',sans-serif; font-size:13px; font-weight:500; outline:none; box-sizing:border-box;" placeholder="+92 300 0000000 (optional)">
                </div>
                <p id="wl-error" style="font-size:11px; color:#ff4444; margin-bottom:8px; display:none;"></p>
                <button id="wl-btn" onclick="joinWaitlist()" style="width:100%; background:var(--accent-color); color:#000; font-family:'Unbounded',sans-serif; font-size:11px; font-weight:800; text-transform:uppercase; letter-spacing:1px; padding:15px 20px; border-radius:12px; border:none; cursor:pointer;">NOTIFY ME FIRST →</button>
            </div>
            <div id="wl-success" style="display:none; align-items:flex-start; gap:14px; padding:18px; background:rgba(0,255,135,0.05); border:1px solid rgba(0,255,135,0.15); border-radius:14px;">
                <div style="width:32px; height:32px; border-radius:50%; background:var(--accent-color); color:#000; font-size:16px; font-weight:800; display:flex; align-items:center; justify-content:center; flex-shrink:0;">✓</div>
                <div>
                    <p style="font-family:'Unbounded',sans-serif; font-size:11px; font-weight:800; color:var(--accent-color); letter-spacing:1px; margin-bottom:4px;">YOU'RE IN THE LIST</p>
                    <p style="font-size:12px; color:var(--text-muted); line-height:1.5;">We'll hit you the moment the next drop goes live.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ════════════════════════════════════════════════════════ -->
<!--  ARCHIVE: Proof of past drops (at bottom)               -->
<!-- ════════════════════════════════════════════════════════ -->
<% if (pastDrops && pastDrops.length > 0) { %>
<div style="max-width:860px; margin: 0 auto 80px; padding: 0 5%;">
    <div style="font-size:10px; font-weight:700; letter-spacing:3px; color:#2a2a2a; text-transform:uppercase; padding-bottom:12px; border-bottom:1px solid #111; margin-bottom:12px;">Archive</div>
    <div style="display:flex; flex-direction:column; gap:8px;">
        <% pastDrops.forEach(pd => { %>
            <div style="display:flex; align-items:center; gap:20px; padding:12px 18px; background:#070707; border:1px solid #111; border-radius:10px;">
                <span style="font-family:'Unbounded',sans-serif; font-size:9px; font-weight:800; color:#2a2a2a; letter-spacing:1px; min-width:80px;"><%= pd.label %></span>
                <span style="font-size:12px; color:#333; flex:1; text-transform:uppercase; letter-spacing:0.5px;"><%= pd.title %></span>
                <span style="font-size:9px; font-weight:700; color:#2a2a2a; text-transform:uppercase; letter-spacing:1px;">Sold Out · <%= pd.totalUnits %> units</span>
            </div>
        <% }) %>
    </div>
</div>
<% } %>


<!-- ════════════════════════════════════════════════════════ -->
<!--  CART NOTIFICATION (unchanged)                          -->
<!-- ════════════════════════════════════════════════════════ -->
<div id="cart-notification" class="notification">
    <div class="notification-content">
        <span class="notification-icon">⚡</span>
        <div class="notification-text">
            <span class="title">ADDED TO BAG</span>
            <span class="sub-text">Item secured. Ready for <%= activeDrop ? activeDrop.label : 'Drop #01' %>.</span>
        </div>
    </div>
    <div class="progress-bar"></div>
</div>


<!-- ════════════════════════════════════════════════════════ -->
<!--  SCRIPTS                                                -->
<!-- ════════════════════════════════════════════════════════ -->
<script>

    /* ── COUNTDOWN ─────────────────────────────────────── */
    (function () {
        const el = document.getElementById('countdown');
        if (!el) return;

        const endDate = new Date(el.getAttribute('data-end'));

        function pad(n) { return String(n).padStart(2, '0'); }

        function tick() {
            const diff = endDate - new Date();
            if (diff <= 0) {
                ['days','hours','mins','secs'].forEach(id => {
                    document.getElementById('cd-' + id).textContent = '00';
                });
                clearInterval(timer);
                return;
            }
            document.getElementById('cd-days').textContent  = pad(Math.floor(diff / 86400000));
            document.getElementById('cd-hours').textContent = pad(Math.floor((diff % 86400000) / 3600000));
            document.getElementById('cd-mins').textContent  = pad(Math.floor((diff % 3600000) / 60000));
            document.getElementById('cd-secs').textContent  = pad(Math.floor((diff % 60000) / 1000));
        }

        tick();
        const timer = setInterval(tick, 1000);
    })();


    /* ── WAITLIST ──────────────────────────────────────── */
    async function joinWaitlist() {
        const email   = document.getElementById('wl-email').value.trim();
        const phone   = document.getElementById('wl-phone').value.trim();
        const errorEl = document.getElementById('wl-error');
        const btn     = document.getElementById('wl-btn');

        errorEl.style.display = 'none';

        if (!email || !email.includes('@')) {
            errorEl.textContent = 'Enter a valid email.';
            errorEl.style.display = 'block';
            return;
        }

        btn.textContent = 'JOINING...';
        btn.disabled = true;

        try {
            const res  = await fetch('/waitlist', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email, phone, dropLabel: '<%= activeDrop ? activeDrop.label : "Drop #01" %>' })
            });
            const text = await res.text();
            let data;
            try { data = JSON.parse(text); } catch(e) { data = { success: false, message: 'Server error.' }; }

            if (data.success) {
                document.getElementById('wl-form').style.display    = 'none';
                document.getElementById('wl-success').style.display = 'flex';
            } else {
                errorEl.textContent = data.message || 'Something went wrong.';
                errorEl.style.display = 'block';
                btn.textContent = 'NOTIFY ME FIRST →';
                btn.disabled = false;
            }
        } catch (err) {
            errorEl.textContent = 'Network error. Try again.';
            errorEl.style.display = 'block';
            btn.textContent = 'NOTIFY ME FIRST →';
            btn.disabled = false;
        }
    }


    /* ── CART (unchanged) ──────────────────────────────── */
    async function addToBag(productId) {
        try {
            const response = await fetch(`/cart/add/${productId}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            });
            const data = await response.json();
            if (data.success) {
                const cartCountEl = document.getElementById('cart-count');
                cartCountEl.innerText = data.cartCount;
                cartCountEl.style.display = 'inline';
                showNotification();
            }
        } catch (error) {
            console.error('Error adding to cart:', error);
        }
    }

    function showNotification() {
        const notifyBox = document.getElementById('cart-notification');
        notifyBox.classList.add('show');
        setTimeout(() => notifyBox.classList.remove('show'), 2500);
    }

    function goToCart() { window.location.href = '/cart'; }

</script>
</body>
</html>
